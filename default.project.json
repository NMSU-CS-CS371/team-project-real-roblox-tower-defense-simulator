{
  "name": "MyGame",
  "tree": {
    "$className": "DataModel",

    "Workspace": {
      "$ignoreUnknown": true,
      "Grassland": {
        "$path": "assets/Grassland.rbxm"
      }
    },

    "ReplicatedStorage": {
      "Shared": {
        "$path": "src/shared"
      }
    },

    "ServerStorage": {
      "$ignoreUnknown": true,
      "Mobs": {
        "$className": "Folder",
        "Rig": {
          "$path": "assets/Mobs/Rig.rbxm"
        }
      }
    },

    "ServerScriptService": {
      "$ignoreUnknown": true,
      "Main": {
        "$path": "src/server/Main"
      }
    },

    "StarterPlayer": {
      "StarterPlayerScripts": {
        "Client": {
          "$path": "src/client"
        }
      }
    }
  }
}
